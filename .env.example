# ============================================================
# Reminder Bot - configuration
# Copy this file to ".env" and fill in your values.
# NEVER share or commit the real .env file.
# ============================================================

# --- Required ------------------------------------------------

# Discord bot token.
# Get it at https://discord.com/developers/applications
#   -> your application -> Bot -> Reset Token
DISCORD_TOKEN=paste-your-discord-bot-token-here

# YOUR Discord user ID (the bot owner). The bot DMs confirmations,
# reminders, and notifications to this account.
# Discord -> Settings -> Advanced -> enable Developer Mode,
# then right-click your own name -> Copy User ID
OWNER_ID=123456789012345678

# Gemini API key (free, no credit card).
# Get it at https://aistudio.google.com -> Get API key
GEMINI_API_KEY=paste-your-gemini-api-key-here

# Optional BACKUP keys. When the key above runs out of quota, the
# bot automatically moves to the next one and keeps working. Add as
# many as you like by counting up - _2, _3, _4 ... up to _20.
# Keys from DIFFERENT Google accounts get you separate quotas;
# extra keys on the same account usually share one.
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# --- Recommended ---------------------------------------------

# Your server's ID. If set, slash commands appear in that server
# instantly. If left empty, commands sync globally (can take up
# to an hour to show up the first time).
GUILD_ID=

# --- AI settings ---------------------------------------------

# Gemini model used for chat analysis. gemini-3.1-flash-lite is
# fast, cheap, and reliably available on the free tier.
# gemini-3.5-flash is stronger but often answers 503 (overloaded).
# The gemini-2.5-* models have been retired and now return 404.
# If detection stops working, try another model here first.
GEMINI_MODEL=gemini-3.1-flash-lite

# Backup model, used automatically when the one above is
# overloaded (503) or has been retired (404). The bot retries a
# couple of times first, then switches over on its own and
# remembers the bad model for 5 minutes. Empty = no fallback.
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# Minimum AI confidence (0.0 - 1.0) before the bot sends you a
# Confirm/Ignore prompt. Raise it if you get silly detections.
CONFIDENCE_THRESHOLD=0.6

# Internal safety cap on AI calls per day. The Gemini free tier
# allows ~1500/day; this keeps a hyperactive channel far below it.
# You get a DM if this cap is ever reached.
MAX_AI_CALLS_PER_DAY=200

# --- Chatbot (replies when you @mention it) ------------------

# Reply conversationally when someone @mentions the bot or replies
# to one of its messages. @everyone / @here is always ignored.
# This is only the starting value - /settings chatbot toggle
# changes it from Discord and that choice wins.
CHATBOT_ENABLED=true

# Optional SEPARATE Gemini key just for chat replies, so chatting
# never eats the detection key's free-tier quota. Make a second key
# at https://aistudio.google.com. Empty = reuse GEMINI_API_KEY
# (backups included).
CHATBOT_API_KEY=
# Backup chat keys - same counting-up rule as GEMINI_API_KEY_2.
# CHATBOT_API_KEY_2=

# Optional model for chat replies. A cheaper/faster one usually
# belongs here, since chat is the higher-volume path.
# Empty = same as GEMINI_MODEL.
CHATBOT_MODEL=

# Backup model for chat replies, same idea as GEMINI_FALLBACK_MODEL.
# Empty = use whatever GEMINI_FALLBACK_MODEL is set to.
CHATBOT_FALLBACK_MODEL=

# Optional web search provider used only for conversational @mention questions.
# Supported values: serpapi, google_cse. Leave empty to disable.
WEB_SEARCH_PROVIDER=
# API key for the search provider.
WEB_SEARCH_API_KEY=
# For Google Custom Search only: the search engine ID (cx parameter).
WEB_SEARCH_ENGINE_ID=
# How many web search results to include in the prompt. Keep this small.
WEB_SEARCH_RESULT_COUNT=3

# Internal safety cap on chat replies per day. Separate from
# MAX_AI_CALLS_PER_DAY so chatter can never starve detection.
CHATBOT_MAX_CALLS_PER_DAY=200

# Seconds each person must wait between pings, so one spammer can't
# burn the daily cap. 0 = no cooldown (default). Change it live with
# /settings chatbot cooldown (that overrides this value).
CHATBOT_COOLDOWN_SECONDS=0

# --- Context detection ---------------------------------------

# How many recent channel messages are sent along with a flagged
# message so the AI understands the conversation. 0 disables context.
CONTEXT_MESSAGES=8

# After a detection, messages from the same people in that channel
# are AI-checked even without keywords, for this many minutes.
# Catches follow-ups like "next month nalang pala". 0 disables.
HOT_WINDOW_MINUTES=10

# Max keyword-less AI checks per hot window (cost bound).
MAX_FOLLOWUPS_PER_WINDOW=10

# --- Behavior ------------------------------------------------

# Currency assumed when someone says "500" with no symbol.
DEFAULT_CURRENCY=₱

# Hour of day (0-23) a reminder fires when only a date was given.
DEFAULT_REMINDER_HOUR=9

# --- Google Calendar sync (optional) -------------------------

# Mirrors Discord scheduled events onto Google Calendars (yours and
# anyone who runs /calendar link). Leave as-is to keep the feature
# off. Full setup guide: README.md "Google Calendar sync".

# Path to the service-account JSON key from Google Cloud. The key
# file EXISTING is what switches calendar sync on.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Your own calendar's ID (optional - you can also just run
# /calendar link in Discord like everyone else).
GOOGLE_CALENDAR_ID=

# Comma-separated server IDs whose events get synced.
# Empty = just the GUILD_ID server.
CALENDAR_GUILD_IDS=

# Discord voice events often have no end time, but Google requires
# one - assume events run this many hours.
CALENDAR_DEFAULT_EVENT_HOURS=1

# --- Logging -------------------------------------------------

# INFO for normal use. DEBUG shows every detection decision:
# prescan matches, scope gating, AI responses, duplicate checks,
# reminder-loop evaluations. Watch with: journalctl -u reminderbot -f
LOG_LEVEL=DEBUG

# --- Optional ------------------------------------------------

# Where the SQLite database lives (default: debts.db next to bot.py)
# DB_PATH=/home/pi/discord-debt-bot/debts.db
